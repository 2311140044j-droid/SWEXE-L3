<h1>ブックマークを編集</h1>

<% if flash[:notice] %>
  <div style="padding: 10px; margin: 10px 0; background-color: #d4edda; color: #155724; border-radius: 5px;">
    <%= flash[:notice] %>
  </div>
<% end %>

<% if flash[:alert] %>
  <div style="padding: 10px; margin: 10px 0; background-color: #f8d7da; color: #721c24; border-radius: 5px;">
    <%= flash[:alert] %>
  </div>
<% end %>


<%= form_with(model: @bookmark, local: true, class: "mb-3") do |f| %>
  <% if @bookmark.errors.any? %>
    <div class="alert alert-danger">
      <h4>エラーがあります：</h4>
      <ul>
        <% @bookmark.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :title, "タイトル" %>
    <%= f.text_field :title, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :url, "URL" %>
    <%= f.text_field :url, class: "form-control" %>
  </div>

  <%= f.submit "更新する", class: "btn btn-primary" %>
  <%= link_to "戻る", bookmarks_path, class: "btn btn-secondary" %>
<% end %>